---
type Card = {
  title: string;
  text: string;
  iconSvg: string;
  desktopPlacement: string;
};

const cards: Card[] = [
  {
    title: "Trusted Experience",
    text: "Over five years of mastering automation tools to deliver high-performing workflows.",
    desktopPlacement: "md:col-start-2 md:row-start-1",
    iconSvg: `<svg class="te-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="5" y="5" width="30" height="30" stroke="#336FE8"/>
      <rect x="5" y="5" width="30" height="30" stroke="#336FE8"/>
      <rect x="5" y="5" width="30" height="30" stroke="#336FE8"/>
    </svg>`,
  },
  {
    title: "Direct Engineering",
    text: "No intermediaries: collaborate directly with the architects building your system.",
    desktopPlacement: "md:col-start-3 md:row-start-2",
    iconSvg: `<svg class="de-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <g clip-path="url(#clip-de)">
        <rect x="24" y="10" width="4" height="4" rx="2" fill="#336FE8"/>
        <rect x="6" y="13" width="4" height="4" rx="2" fill="#336FE8"/>
        <rect width="4" height="4" rx="2" fill="#336FE8"/>
        <rect x="36" width="4" height="4" rx="2" fill="#336FE8"/>
        <path d="M0 39H40" stroke="#336FE8"/>
      </g>
      <defs><clipPath id="clip-de"><rect width="40" height="40"/></clipPath></defs>
    </svg>`,
  },
  {
    title: "Efficient Deployment",
    text: "Expert proficiency ensuring rapid delivery without compromising system stability.",
    desktopPlacement: "md:col-start-1 md:row-start-3",
    iconSvg: `<svg class="ed-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <circle cx="20" cy="20" r="17.5" stroke="#336FE8"/>
      <circle cx="20" cy="20" r="17.5" stroke="#336FE8"/>
      <circle cx="20" cy="20" r="17.5" stroke="#336FE8"/>
    </svg>`,
  },
  {
    title: "European Excellence",
    text: "Global standards and rigorous technical precision in every workflow.",
    desktopPlacement: "md:col-start-2 md:row-start-4",
    iconSvg: `<svg class="ee-icon" width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect x="2" y="2" width="36" height="36" stroke="#336FE8"/>
      <rect x="11" y="11" width="18" height="18" stroke="#336FE8"/>
      <rect x="18" y="18" width="4" height="4" rx="2" fill="#336FE8"/>
    </svg>`,
  },
];
---

<section id="why-us" class="relative z-10 bg-bg text-text" data-about-section>
  <div class="page-container section">
    <div class="flex flex-col gap-12">
      <div class="md:sticky md:top-0 md:flex md:min-h-screen md:items-center">
        <header
          class="mx-auto flex max-w-4xl flex-col items-center gap-8 text-center"
          data-about-text
        >
          <h6 class="reveal-top delay-2 text-h6 uppercase text-text/20">WHY US</h6>
          <h4
            class="about-reveal text-h4 text-text lg:text-h4-lg"
                data-about-reveal
            >
            We are an independent team of developers specializing in flow automation. We build
            reliable, high-speed systems that help your business run itself.
          </h4>
        </header>
      </div>

      <div>
        <div class="h-[100vh] hidden md:block"></div>

        <div class="grid grid-cols-1 sm:grid-cols-2 sm:gap-4 gap-6 md:grid-cols-3 md:grid-rows-4 md:mb-[100vh]">
          {cards.map((card) => (
            <article class={`reveal-card card hover-border ${card.desktopPlacement}`}>
              <div class="flex flex-col gap-8">
                <Fragment set:html={card.iconSvg} />
                <div class="space-y-2">
                  <h5 class="text-h5 text-text lg:text-h5-lg">{card.title}</h5>
                  <p class="text-body text-text/80">{card.text}</p>
                </div>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

