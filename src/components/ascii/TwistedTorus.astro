---
// src/components/TwistedTorus.astro
// Shape changed to wireframe icosahedron. Tune the three constants below.
---

<div
  id="torus-container"
  class="w-full h-screen fixed top-0 left-0 overflow-hidden pointer-events-none z-0"
  aria-hidden="true"
></div>

<script>
  import * as THREE from 'three';
  import { AsciiEffect } from 'three/addons/effects/AsciiEffect.js';

  // ─── Tuning constants ─────────────────────────────────────────────────────────
  // ICOSA_RADIUS — world-unit radius. Larger = bigger shape. Try 60–140.
  // ICOSA_DETAIL — subdivision level.
  //                0 = raw 20-face icosahedron (very angular, few lines)
  //                1 = 80 faces  (classic geodesic look)       ← default
  //                2 = 320 faces (rounder, denser wireframe)
  // WIRE_WIDTH   — edge thickness passed to the ASCII pass.
  //                1.0 = hairline, 1.5 = default, 3.0 = chunky bars.
  const ICOSA_RADIUS = 80;
  const ICOSA_DETAIL = 1;
  const WIRE_WIDTH   = 3.5;

  // ─── State ────────────────────────────────────────────────────────────────────
  let scene:    THREE.Scene;
  let camera:   THREE.PerspectiveCamera;
  let renderer: THREE.WebGLRenderer;
  let effect:   AsciiEffect;
  let mesh:     THREE.Mesh;
  let animFrameId: number | null = null;
  let fadeTimer:   ReturnType<typeof setTimeout>;
  let canAnimate = false;

  let isInViewport = false;
  let isTabVisible = !document.hidden;

  const container = document.getElementById('torus-container') as HTMLElement;
  const mouse = { x: 0, y: 0 };

  // ─── Loop control ─────────────────────────────────────────────────────────────
  function startLoop() {
    if (animFrameId !== null) return;
    animFrameId = requestAnimationFrame(animate);
  }
  function stopLoop() {
    if (animFrameId === null) return;
    cancelAnimationFrame(animFrameId);
    animFrameId = null;
  }
  function syncLoop() {
    isInViewport && isTabVisible ? startLoop() : stopLoop();
  }

  // ─── Init ─────────────────────────────────────────────────────────────────────
  function init() {
    scene = new THREE.Scene();
    scene.background = null;

    camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 1, 1000);
    camera.position.z = 250;

    renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
    renderer.setClearColor(0x000000, 1);

    // invert: false — characters on bright edges only, background transparent
    effect = new AsciiEffect(renderer, ' .:-=+*#%@', { invert: true, resolution: 0.15 });
    effect.setSize(window.innerWidth, window.innerHeight);

    Object.assign(effect.domElement.style, {
      color: '#336FE8',
      backgroundColor: 'transparent',
      fontFamily: 'monospace',
      fontSize: '18px',
      fontWeight: '400',
      textShadow: `
        0px 0px 4px rgba(72, 22, 238, 1),
        0px 0px 12px rgba(72, 22, 238, 1),
        0px 0px 24px rgba(72, 22, 238, 0.8)
      `,
    });

    container.appendChild(effect.domElement);

    // ─── Geometry ───────────────────────────────────────────────────────────────
    // toNonIndexed() is required so every triangle has 3 unique vertices —
    // shared vertices cannot hold per-triangle barycentric data.
    const baseGeo  = new THREE.IcosahedronGeometry(ICOSA_RADIUS, ICOSA_DETAIL);
    const geometry = baseGeo.toNonIndexed();
    baseGeo.dispose();

    // Barycentric coordinates: each vertex in a triangle gets one corner of
    // the barycentric basis (1,0,0 / 0,1,0 / 0,0,1). The fragment shader uses
    // fwidth() on these to measure distance to the nearest edge — that's what
    // draws the wireframe lines without any extra geometry.
    const count = geometry.attributes.position.count;
    const bary  = new Float32Array(count * 3);
    for (let i = 0; i < count; i += 3) {
      bary.set([1, 0, 0],  i      * 3);
      bary.set([0, 1, 0], (i + 1) * 3);
      bary.set([0, 0, 1], (i + 2) * 3);
    }
    geometry.setAttribute('barycentric', new THREE.BufferAttribute(bary, 3));

    // ─── Shader ─────────────────────────────────────────────────────────────────
    const material = new THREE.ShaderMaterial({
      extensions:  { derivatives: true }, // required for fwidth()
      side:        THREE.DoubleSide,
      vertexShader: /* glsl */ `
        attribute vec3 barycentric;
        varying vec3 vBarycentric;
        varying vec3 vNormal;
        varying vec3 vViewPosition;

        void main() {
          vBarycentric  = barycentric;
          vNormal       = normalize(normalMatrix * normal);
          vec4 mvPos    = modelViewMatrix * vec4(position, 1.0);
          vViewPosition = -mvPos.xyz;
          gl_Position   = projectionMatrix * mvPos;
        }
      `,
      fragmentShader: /* glsl */ `
        varying vec3 vBarycentric;
        varying vec3 vNormal;
        varying vec3 vViewPosition;

        // 1.0 at triangle edges, 0.0 in the interior.
        // wireWidth maps directly to WIRE_WIDTH constant above.
        float edgeFactor(float wireWidth) {
          vec3 d  = fwidth(vBarycentric);
          vec3 a3 = smoothstep(vec3(0.0), d * wireWidth, vBarycentric);
          return 0.9 - min(min(a3.x, a3.y), a3.z);
        }

        void main() {
          vec3 normal  = normalize(vNormal);
          vec3 viewDir = normalize(vViewPosition);

          float edge = edgeFactor(${WIRE_WIDTH.toFixed(1)});

          // Rim glow on silhouette so the sphere reads as a 3D volume
          // even when only wireframe edges are lit
          float rim  = pow(0.95 - max(dot(viewDir, normal), 0.0), 2.5) * 0.35;

          gl_FragColor = vec4(vec3(edge + rim), 1.0);
        }
      `,
    });

    mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    container.style.opacity = '0';
    fadeTimer = setTimeout(() => {
      canAnimate = true;
      container.style.transition = 'opacity 3.5s ease';
      container.style.opacity = '1';
    }, 5000);

    // ─── Observers ──────────────────────────────────────────────────────────────
    const intersectionObserver = new IntersectionObserver(
      ([entry]) => { isInViewport = entry.isIntersecting; syncLoop(); },
      { threshold: 0 }
    );
    intersectionObserver.observe(container);

    const onVisibilityChange = () => { isTabVisible = !document.hidden; syncLoop(); };
    document.addEventListener('visibilitychange', onVisibilityChange);
    window.addEventListener('resize', onResize);
    window.addEventListener('mousemove', onMouseMove);

    document.addEventListener('astro:before-swap', () => {
      stopLoop();
      clearTimeout(fadeTimer);
      intersectionObserver.disconnect();
      document.removeEventListener('visibilitychange', onVisibilityChange);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('mousemove', onMouseMove);
      geometry.dispose();
      material.dispose();
      renderer.dispose();
      effect.domElement.remove();
    }, { once: true });
  }

  // ─── Handlers ─────────────────────────────────────────────────────────────────
  function onResize() {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    effect.setSize(window.innerWidth, window.innerHeight);
  }

  function onMouseMove(e: MouseEvent) {
    mouse.x =  (e.clientX / window.innerWidth)  * 2 - 1;
    mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
  }

  // ─── Animation loop ───────────────────────────────────────────────────────────
  function animate() {
    animFrameId = requestAnimationFrame(animate);

    const vFOV          = camera.fov * (Math.PI / 180);
    const visibleHeight = 2 * Math.tan(vFOV / 2) * camera.position.z;
    const mobileFactor  = window.innerWidth < 768 ? 0.99 : 1.2;
    const targetScale   = (visibleHeight * mobileFactor) / 170;

    if (canAnimate) {
      mesh.scale.x += (targetScale - mesh.scale.x) * 0.02;
      mesh.scale.y += (targetScale - mesh.scale.y) * 0.02;
      mesh.scale.z += (targetScale - mesh.scale.z) * 0.02;
    }

    // Position parallax — preserved
    mesh.position.x += (mouse.x * 15 - mesh.position.x) * 0.05;
    mesh.position.y += (mouse.y * 15 - mesh.position.y) * 0.05;

    // Multi-axis tumble: Y spin + gentle X roll so the wireframe never
    // presents the same face twice and reads as a full 3D volume
    mesh.rotation.y += 0.0003;
    mesh.rotation.x += 0.0003;

    // Mouse tilt parallax — preserved
    mesh.rotation.x += (mouse.y * 0.25 - mesh.rotation.x) * 0.01;
    mesh.rotation.z += (mouse.x * 0.25 - mesh.rotation.z) * 0.01;

    effect.render(scene, camera);
  }

  // ─── Boot ─────────────────────────────────────────────────────────────────────
  init();
</script>