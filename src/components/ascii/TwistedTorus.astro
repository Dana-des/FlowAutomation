---
// src/components/TwistedTorus.astro
---

<!--
  Both containers are full-viewport so Three.js renders at a consistent
  aspect ratio. The torus mesh is positioned in world space at its corner —
  no CSS corner tricks needed. overflow-hidden clips whatever goes off-screen.
-->
<div id="torus-bl" class="w-full h-screen fixed inset-0 overflow-hidden pointer-events-none z-0" aria-hidden="true"></div>
<div id="torus-tr" class="w-full h-screen fixed inset-0 overflow-hidden pointer-events-none z-0" aria-hidden="true"></div>

<script>
  import * as THREE from 'three';
  import { AsciiEffect } from 'three/addons/effects/AsciiEffect.js';
  import { ParametricGeometry } from 'three/addons/geometries/ParametricGeometry.js';

  // ─── Shared state ─────────────────────────────────────────────────────────────
  const mouse        = { x: 0, y: 0 };
  const BASE_TILT    =  35 * (Math.PI / 180); // 35° — used ± per instance
  let   isTabVisible = !document.hidden;

  // ─── Instance config ──────────────────────────────────────────────────────────
  // Each torus gets a config that makes it the polar opposite of the other:
  //   rotDir      — +1 / -1  : clockwise vs counter-clockwise Y rotation
  //   cornerX/Y   — ±0.5     : world-space corner fraction (calculated per frame)
  //   parallaxDir — +1 / -1  : follows mouse vs pushes away from mouse
  //   baseTilt    — ±35°     : initial X tilt mirrors between the two
  interface TorusConfig {
    rotDir:      1 | -1;
    cornerX:     0.5 | -0.5; // fraction of visible half-width
    cornerY:     0.5 | -0.5; // fraction of visible half-height
    parallaxDir: 1 | -1;
    baseTilt:    number;
  }

  const configs: [string, TorusConfig][] = [
    // Bottom-left: tilts toward viewer from top, follows mouse, spins CW
    ['torus-bl', { rotDir: 1,  cornerX: -0.4, cornerY: -0.4, parallaxDir:  1, baseTilt: -BASE_TILT }],
    // Top-right:   tilts toward viewer from bottom, pushes away, spins CCW
    ['torus-tr', { rotDir: -1, cornerX:  0.4, cornerY:  0.4, parallaxDir: -1, baseTilt:  BASE_TILT }],
  ];

  // ─── Geometry + material (shared — uploaded to GPU once) ─────────────────────
  const twistedTorusFunc = (u: number, v: number, target: THREE.Vector3) => {
    const radius = 60;
    const tube   = 25;
    const twists = 0;
    const uAngle = u * Math.PI * 2;
    const vAngle = v * Math.PI * 2 + uAngle * twists;
    target.set(
      (radius + tube * Math.cos(vAngle)) * Math.cos(uAngle),
      (radius + tube * Math.cos(vAngle)) * Math.sin(uAngle),
      tube * Math.sin(vAngle)
    );
  };
  const sharedGeometry = new ParametricGeometry(twistedTorusFunc, 150, 4);
  const sharedMaterial = new THREE.ShaderMaterial({
    vertexShader: /* glsl */ `
      varying vec3 vNormal;
      varying vec3 vViewPosition;
      void main() {
        vNormal = normalize(normalMatrix * normal);
        vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
        vViewPosition = -mvPosition.xyz;
        gl_Position = projectionMatrix * mvPosition;
      }
    `,
    fragmentShader: /* glsl */ `
      varying vec3 vNormal;
      varying vec3 vViewPosition;
      void main() {
        vec3 normal  = normalize(vNormal);
        vec3 viewDir = normalize(vViewPosition);
        float rim = pow(1.0 - max(dot(viewDir, normal), 0.0), 2.0);
        gl_FragColor = vec4(vec3(rim * 3.5), 1.0);
      }
    `,
  });

  // ─── Factory ──────────────────────────────────────────────────────────────────
  function createTorusInstance(containerId: string, cfg: TorusConfig) {
    const container = document.getElementById(containerId);
    if (!container) return null;

    let scene:    THREE.Scene;
    let camera:   THREE.PerspectiveCamera;
    let renderer: THREE.WebGLRenderer;
    let effect:   AsciiEffect;
    let torus:    THREE.Mesh;
    let animFrameId: number | null = null;
    let canAnimate   = false;
    let isInViewport = false;
    let fadeTimer:   ReturnType<typeof setTimeout>;

    // ── Loop control ────────────────────────────────────────────────────────
    function startLoop() {
      if (animFrameId !== null) return;
      animFrameId = requestAnimationFrame(animate);
    }
    function stopLoop() {
      if (animFrameId === null) return;
      cancelAnimationFrame(animFrameId);
      animFrameId = null;
    }
    function syncLoop() {
      isInViewport && isTabVisible ? startLoop() : stopLoop();
    }

    // ── Init ────────────────────────────────────────────────────────────────
    function init() {
      scene = new THREE.Scene();
      scene.background = null;

      camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 1, 1000);
      camera.position.z = 250;

      renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true });
      renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
      renderer.setClearColor(0x000000, 0);

      effect = new AsciiEffect(renderer, ' .:-=+*#%@', { invert: false, resolution: 0.15 });
      effect.setSize(window.innerWidth, window.innerHeight);

      Object.assign(effect.domElement.style, {
        color: '#336FE8',
        backgroundColor: 'transparent',
        fontFamily: 'monospace',
        fontSize: '18px',
        fontWeight: '400',
        textShadow: `
          0px 0px 4px rgba(51, 111, 232, 0.8),
          0px 0px 12px rgba(51, 111, 232, 0.8),
          0px 0px 24px rgba(51, 111, 232, 0.8)
        `,
      });

      container.appendChild(effect.domElement);

      // Each torus is a separate mesh but shares geometry + material —
      // no extra GPU upload, just two draw calls with different transforms.
      torus = new THREE.Mesh(sharedGeometry, sharedMaterial);
      torus.rotation.x = cfg.baseTilt;
      torus.scale.setScalar(3.0);
      scene.add(torus);

      // Fade in
      container.style.opacity = '0';
      fadeTimer = setTimeout(() => {
        canAnimate = true;
        container.style.transition = 'opacity 3.5s ease';
        container.style.opacity = '1';
      }, 5000);

      const io = new IntersectionObserver(
        ([entry]) => { isInViewport = entry.isIntersecting; syncLoop(); },
        { threshold: 0 }
      );
      io.observe(container);

      cleanupFns.push(() => {
        io.disconnect();
        clearTimeout(fadeTimer);
        stopLoop();
        renderer.dispose();
        effect.domElement.remove();
      });
    }

    // ── Animate ─────────────────────────────────────────────────────────────
    function animate() {
      animFrameId = requestAnimationFrame(animate);

      const vFOV = camera.fov * (Math.PI / 180);
      const visibleHeight = 2 * Math.tan(vFOV / 2) * camera.position.z;
      const visibleWidth  = visibleHeight * (window.innerWidth / window.innerHeight);

      // Corner anchor in world space — the torus center rests exactly
      // at the viewport corner, extending inward toward screen centre.
      const cornerWX = cfg.cornerX * visibleWidth;
      const cornerWY = cfg.cornerY * visibleHeight;

      // Parallax offset — opposite signs between instances creates a
      // "spread apart / pull together" feel as the mouse moves.
      const px = cfg.parallaxDir * mouse.x * 22;
      const py = cfg.parallaxDir * mouse.y * 22;

      // Scale — larger than the original centered torus so a generous
      // arc is visible from each corner. Mobile slightly smaller.
      if (canAnimate) {
        const mobileFactor = window.innerWidth < 768 ? 1.1 : 1.5;
        const targetScale  = (visibleHeight * mobileFactor) / 170;
        torus.scale.x += (targetScale - torus.scale.x) * 0.02;
        torus.scale.y += (targetScale - torus.scale.y) * 0.02;
        torus.scale.z += (targetScale - torus.scale.z) * 0.02;
      }

      // Lerp position toward corner + parallax offset
      torus.position.x += (cornerWX + px - torus.position.x) * 0.05;
      torus.position.y += (cornerWY + py - torus.position.y) * 0.05;

      // Y rotation — polar: one CW, one CCW
      torus.rotation.y += cfg.rotDir * 0.0003;

      // Tilt parallax — polar: one leans with mouse, one leans against
      torus.rotation.x += (cfg.baseTilt + cfg.parallaxDir * mouse.y * 0.3 - torus.rotation.x) * 0.01;
      torus.rotation.z += (cfg.parallaxDir * mouse.x * 0.3 - torus.rotation.z) * 0.01;

      effect.render(scene, camera);
    }

    // ── Resize ──────────────────────────────────────────────────────────────
    function onResize() {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      effect.setSize(window.innerWidth, window.innerHeight);
    }

    const cleanupFns: (() => void)[] = [];
    init();

    return { syncLoop, onResize, cleanup: () => cleanupFns.forEach(fn => fn()) };
  }

  // ─── Boot ─────────────────────────────────────────────────────────────────────
  const instances = configs
    .map(([id, cfg]) => createTorusInstance(id, cfg))
    .filter(Boolean) as NonNullable<ReturnType<typeof createTorusInstance>>[];

  // ─── Shared listeners ─────────────────────────────────────────────────────────
  window.addEventListener('mousemove', (e: MouseEvent) => {
    mouse.x =  (e.clientX / window.innerWidth)  * 2 - 1;
    mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
  });

  document.addEventListener('visibilitychange', () => {
    isTabVisible = !document.hidden;
    instances.forEach(inst => inst.syncLoop());
  });

  window.addEventListener('resize', () => {
    instances.forEach(inst => inst.onResize());
  });

  // ─── Cleanup ──────────────────────────────────────────────────────────────────
  document.addEventListener('astro:before-swap', () => {
    instances.forEach(inst => inst.cleanup());
    sharedGeometry.dispose();
    sharedMaterial.dispose();
  }, { once: true });
</script>