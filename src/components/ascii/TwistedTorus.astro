---
// src/components/TwistedTorus.astro
// No props needed — all values are preserved from the original
---

<div
  id="torus-container"
  class="w-full h-screen fixed top-0 left-0 overflow-hidden pointer-events-none z-0"
  aria-hidden="true"
></div>

<script>
  import * as THREE from 'three';
  import { AsciiEffect } from 'three/addons/effects/AsciiEffect.js';
  import { ParametricGeometry } from 'three/addons/geometries/ParametricGeometry.js';

  // ─── State ───────────────────────────────────────────────────────────────────
  let scene: THREE.Scene;
  let camera: THREE.PerspectiveCamera;
  let renderer: THREE.WebGLRenderer;
  let effect: AsciiEffect;
  let torus: THREE.Mesh;
  let animFrameId: number;
  let canAnimate = false;
  let fadeTimer: ReturnType<typeof setTimeout>;

  const container = document.getElementById('torus-container') as HTMLElement;
  const mouse = { x: 0, y: 0 };
  const BASE_TILT_X = -35 * (Math.PI / 180);

  // ─── Init ─────────────────────────────────────────────────────────────────────
  function init() {
    // Scene
    scene = new THREE.Scene();
    scene.background = null;

    // Camera
    camera = new THREE.PerspectiveCamera(
      50,
      window.innerWidth / window.innerHeight,
      1,
      1000
    );
    camera.position.z = 250;

    // Renderer — pixel ratio capped at 1 for perf (5 animations on page)
    renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
    renderer.setClearColor(0x000000, 0);

    // ASCII Effect
    effect = new AsciiEffect(renderer, ' .:-=+*#%@', {
      invert: false,
      resolution: 0.15,
    });
    effect.setSize(window.innerWidth, window.innerHeight);

    // Styles — preserved exactly from original
    Object.assign(effect.domElement.style, {
      color: '#336FE8',
      backgroundColor: 'transparent',
      fontFamily: 'monospace',
      fontSize: '18px',
      fontWeight: '500',
      textShadow: `
        0px 0px 4px rgba(51, 111, 232, 0.6),
        0px 0px 12px rgba(51, 111, 232, 0.8),
        0px 0px 24px rgba(51, 111, 232, 0.8)
      `,
    });

    container.appendChild(effect.domElement);

    // ─── Geometry: Twisted Torus (ParametricGeometry) ───────────────────────
    const twistedTorusFunc = (
      u: number,
      v: number,
      target: THREE.Vector3
    ) => {
      const radius = 60;  // main ring radius — preserved
      const tube   = 25;  // tube thickness — preserved
      const twists = 2;   // tube rotations — preserved

      const uAngle = u * Math.PI * 2;
      const vAngle = v * Math.PI * 2 + uAngle * twists;

      target.set(
        (radius + tube * Math.cos(vAngle)) * Math.cos(uAngle),
        (radius + tube * Math.cos(vAngle)) * Math.sin(uAngle),
        tube * Math.sin(vAngle)
      );
    };

    // 120 tubular × 4 radial = sharp square-twist look — preserved
    const geometry = new ParametricGeometry(twistedTorusFunc, 120, 4);

    // ─── Shader: Rim / Glow ──────────────────────────────────────────────────
    const material = new THREE.ShaderMaterial({
      vertexShader: /* glsl */ `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
          vViewPosition = -mvPosition.xyz;
          gl_Position = projectionMatrix * mvPosition;
        }
      `,
      fragmentShader: /* glsl */ `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        void main() {
          vec3 normal  = normalize(vNormal);
          vec3 viewDir = normalize(vViewPosition);
          float rim = pow(1.0 - max(dot(viewDir, normal), 0.0), 3.0);
          gl_FragColor = vec4(vec3(rim * 3.5), 1.0);
        }
      `,
    });

    torus = new THREE.Mesh(geometry, material);
    torus.rotation.x = BASE_TILT_X;
    torus.scale.setScalar(3.0);
    scene.add(torus);

    // Start invisible, fade in after 5 s — preserved
    container.style.opacity = '0';
    fadeTimer = setTimeout(() => {
      canAnimate = true;
      container.style.transition = 'opacity 3.5s ease-in-out';
      container.style.opacity = '1';
    }, 4000);

    window.addEventListener('resize', onResize);
    window.addEventListener('mousemove', onMouseMove);
  }

  // ─── Resize ───────────────────────────────────────────────────────────────────
  function onResize() {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    effect.setSize(window.innerWidth, window.innerHeight);
  }

  // ─── Mouse ────────────────────────────────────────────────────────────────────
  function onMouseMove(e: MouseEvent) {
    mouse.x =  (e.clientX / window.innerWidth)  * 2 - 1;
    mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
  }

  // ─── Animation loop ───────────────────────────────────────────────────────────
  function animate() {
    animFrameId = requestAnimationFrame(animate);

    // Scale to fill 120 vh — preserved
    const vFOV = camera.fov * (Math.PI / 180);
    const visibleHeight = 2 * Math.tan(vFOV / 2) * camera.position.z;
    const targetScale = (visibleHeight * 1.2) / 170;

    if (canAnimate) {
      torus.scale.x += (targetScale - torus.scale.x) * 0.02;
      torus.scale.y += (targetScale - torus.scale.y) * 0.02;
      torus.scale.z += (targetScale - torus.scale.z) * 0.02;
    }

    // Parallax — preserved
    torus.position.x += (mouse.x * 15 - torus.position.x) * 0.05;
    torus.position.y += (mouse.y * 15 - torus.position.y) * 0.05;

    // Slow rotation + tilt parallax — preserved
    torus.rotation.y += 0.0003;
    torus.rotation.x += (BASE_TILT_X + mouse.y * 0.25 - torus.rotation.x) * 0.01;
    torus.rotation.z += (mouse.x * 0.25 - torus.rotation.z) * 0.01;

    effect.render(scene, camera);
  }

  // ─── Cleanup (Astro View Transitions / unmount) ───────────────────────────────
  function cleanup() {
    cancelAnimationFrame(animFrameId);
    clearTimeout(fadeTimer);
    window.removeEventListener('resize', onResize);
    window.removeEventListener('mousemove', onMouseMove);
    renderer.dispose();
    effect.domElement.remove();
  }

  // Astro View Transitions support
  document.addEventListener('astro:before-swap', cleanup, { once: true });

  // ─── Boot ─────────────────────────────────────────────────────────────────────
  init();
  animate();
</script>