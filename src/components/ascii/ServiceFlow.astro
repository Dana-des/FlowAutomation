---
// src/components/services/ServiceFlow.astro
// Service 1 — Torus Knot / Continuous Flow
---

<div
  id="flow-container"
  class="w-full overflow-hidden relative"
  style="height: 90vh;"
  aria-hidden="true"
></div>

<script>
  import * as THREE from 'three';
  import { AsciiEffect } from 'three/addons/effects/AsciiEffect.js';

  // ─── State ────────────────────────────────────────────────────────────────────
  let scene: THREE.Scene;
  let camera: THREE.PerspectiveCamera;
  let renderer: THREE.WebGLRenderer;
  let effect: AsciiEffect;
  let flowObject: THREE.Mesh;
  let animFrameId: number | null = null;

  // Visibility flags — BOTH must be true to render
  let isInViewport = false;
  let isTabVisible  = !document.hidden;

  const container = document.getElementById('flow-container') as HTMLElement;
  const mouse = { x: 0, y: 0 };

  // ─── Loop control ─────────────────────────────────────────────────────────────
  function startLoop() {
    if (animFrameId !== null) return;
    animFrameId = requestAnimationFrame(animate);
  }

  function stopLoop() {
    if (animFrameId === null) return;
    cancelAnimationFrame(animFrameId);
    animFrameId = null;
  }

  function syncLoop() {
    if (isInViewport && isTabVisible) {
      startLoop();
    } else {
      stopLoop();
    }
  }

  // ─── Init ─────────────────────────────────────────────────────────────────────
  function init() {
    scene = new THREE.Scene();
    scene.background = null;

    // Aspect ratio relative to the container, not the window
    camera = new THREE.PerspectiveCamera(
      50,
      container.clientWidth / container.clientHeight,
      1,
      1000
    );
    camera.position.z = 400; // preserved

    renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
    renderer.setClearColor(0x000000, 0);

    // invert: true — preserved (different from TwistedTorus)
    effect = new AsciiEffect(renderer, ' .:-=+*#%@', {
      invert: true,
      resolution: 0.15,
    });
    effect.setSize(container.clientWidth, container.clientHeight);

    // Blue glow — preserved exactly
    Object.assign(effect.domElement.style, {
      color: '#336FE8',
      backgroundColor: 'transparent',
      fontFamily: 'monospace',
      fontSize: '18px',
      fontWeight: '500',
      textShadow: `
        0px 0px 4px rgba(51, 111, 232, 0.8),
        0px 0px 12px rgba(51, 111, 232, 0.8),
        0px 0px 24px rgba(51, 111, 232, 0.8)
      `,
    });

    container.appendChild(effect.domElement);

    // ─── Geometry: Torus Knot — preserved exactly ────────────────────────────
    const geometry = new THREE.TorusKnotGeometry(80, 25, 128, 32);

    // ─── Shader: Rim lighting — preserved exactly ────────────────────────────
    const material = new THREE.ShaderMaterial({
      vertexShader: /* glsl */ `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          vec4 mvPosition = modelViewMatrix * vec4(position, 1.0);
          vViewPosition = -mvPosition.xyz;
          gl_Position = projectionMatrix * mvPosition;
        }
      `,
      fragmentShader: /* glsl */ `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        void main() {
          vec3 normal  = normalize(vNormal);
          vec3 viewDir = normalize(vViewPosition);
          float rim = pow(1.0 - max(dot(viewDir, normal), 0.0), 3.0);
          gl_FragColor = vec4(vec3(rim * 3.5), 1.0);
        }
      `,
    });

    flowObject = new THREE.Mesh(geometry, material);
    scene.add(flowObject);

    // ─── Observers ──────────────────────────────────────────────────────────────
    const intersectionObserver = new IntersectionObserver(
      ([entry]) => {
        isInViewport = entry.isIntersecting;
        syncLoop();
      },
      { threshold: 0 }
    );
    intersectionObserver.observe(container);

    const onVisibilityChange = () => {
      isTabVisible = !document.hidden;
      syncLoop();
    };
    document.addEventListener('visibilitychange', onVisibilityChange);

    window.addEventListener('resize', onResize);

    // Mouse tracked relative to container rect — preserved
    window.addEventListener('mousemove', onMouseMove);

    // ─── Cleanup ────────────────────────────────────────────────────────────────
    document.addEventListener(
      'astro:before-swap',
      () => {
        stopLoop();
        intersectionObserver.disconnect();
        document.removeEventListener('visibilitychange', onVisibilityChange);
        window.removeEventListener('resize', onResize);
        window.removeEventListener('mousemove', onMouseMove);
        renderer.dispose();
        effect.domElement.remove();
      },
      { once: true }
    );
  }

  // ─── Handlers ─────────────────────────────────────────────────────────────────
  function onResize() {
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    effect.setSize(container.clientWidth, container.clientHeight);
  }

  function onMouseMove(e: MouseEvent) {
    // Container-relative tracking — preserved from original
    const rect = container.getBoundingClientRect();
    mouse.x =  ((e.clientX - rect.left) / rect.width)  * 2 - 1;
    mouse.y = -((e.clientY - rect.top)  / rect.height) * 2 + 1;
  }

  // ─── Animation loop ───────────────────────────────────────────────────────────
  function animate() {
    animFrameId = requestAnimationFrame(animate);

    // Continuous structural rotation — preserved
    flowObject.rotation.y += 0.003;
    flowObject.rotation.x += 0.002;

    // Mouse parallax on rotation — preserved
    flowObject.rotation.x += (mouse.y * 0.3 - flowObject.rotation.x) * 0.05;
    flowObject.rotation.z += (mouse.x * 0.3 - flowObject.rotation.z) * 0.05;

    // Subtle position drift toward cursor — preserved
    flowObject.position.x += (mouse.x * 20 - flowObject.position.x) * 0.05;
    flowObject.position.y += (mouse.y * 20 - flowObject.position.y) * 0.05;

    effect.render(scene, camera);
  }

  // ─── Boot — IntersectionObserver decides when to start ───────────────────────
  init();
</script>