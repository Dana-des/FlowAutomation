---
// src/components/ascii/ServiceFour.astro
// Service 4 — Shield Wireframe / Security
---

<div
  id="service-four-container"
  class="w-full h-full"
  aria-hidden="true"
></div>

<script>
  import * as THREE from 'three';
  import { AsciiEffect } from 'three/addons/effects/AsciiEffect.js';

  // ─── State ────────────────────────────────────────────────────────────────────
  let scene: THREE.Scene;
  let camera: THREE.PerspectiveCamera;
  let renderer: THREE.WebGLRenderer;
  let effect: AsciiEffect;
  let shieldGroup: THREE.Group;
  let outerWireframe: THREE.Mesh;
  let innerSphere: THREE.Mesh;
  let animFrameId: number | null = null;
  let isInViewport = false;
  let isTabVisible = !document.hidden;

  const container = document.getElementById('service-four-container') as HTMLElement;
  const mouse = { x: 0, y: 0 };

  // ─── Loop control ─────────────────────────────────────────────────────────────
  function startLoop() {
    if (animFrameId !== null) return;
    animFrameId = requestAnimationFrame(animate);
  }
  function stopLoop() {
    if (animFrameId === null) return;
    cancelAnimationFrame(animFrameId);
    animFrameId = null;
  }
  function syncLoop() {
    isInViewport && isTabVisible ? startLoop() : stopLoop();
  }

  // ─── Init ─────────────────────────────────────────────────────────────────────
  function init() {
    scene = new THREE.Scene();
    scene.background = null;

    camera = new THREE.PerspectiveCamera(
      50,
      container.clientWidth / container.clientHeight,
      1,
      1000
    );
    camera.position.z = 400; // preserved

    renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
    // Opaque black clear — same as ServiceTwo/Three so invert: true
    // maps dark (background) → transparent, lit areas → characters
    renderer.setClearColor(0x000000, 1);

    effect = new AsciiEffect(renderer, ' .:-=+*#%@', {
      invert: true,
      resolution: 0.15,
    });
    effect.setSize(container.clientWidth, container.clientHeight);

    // Colors and glow — preserved exactly
    Object.assign(effect.domElement.style, {
      color: '#336FE8',
      backgroundColor: 'transparent',
      fontFamily: 'monospace',
      fontSize: '18px',
      fontWeight: '500',
      textShadow: `
        0px 0px 4px rgba(72, 22, 238, 1),
        0px 0px 12px rgba(72, 22, 238, 1),
        0px 0px 24px rgba(72, 22, 238, 0.8)
      `,
    });

    container.appendChild(effect.domElement);

    shieldGroup = new THREE.Group();

    // ─── Geometry — preserved exactly ───────────────────────────────────────
    const outerGeo = new THREE.IcosahedronGeometry(140, 0); // low-poly cage
    const innerGeo = new THREE.SphereGeometry(45, 24, 24);  // solid core

    // ─── Materials — preserved exactly ──────────────────────────────────────

    // Outer: thin wireframe cage
    const wireMaterial = new THREE.MeshBasicMaterial({
      color: 0xffffff,
      wireframe: true,
      transparent: true,
      opacity: 0.8,
    });

    // Inner: solid core shader — pops through the cage wires
    const coreMaterial = new THREE.ShaderMaterial({
      vertexShader: /* glsl */ `
        varying vec3 vNormal;
        void main() {
          vNormal = normalize(normalMatrix * normal);
          gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
        }
      `,
      fragmentShader: /* glsl */ `
        varying vec3 vNormal;
        void main() {
          vec3 lightDir = normalize(vec3(1.0, 1.0, 1.5));
          float diffuse = max(dot(vNormal, lightDir), 0.0);
          // Higher brightness so the core stands out inside the cage — preserved
          float brightness = smoothstep(0.0, 0.8, diffuse + 0.4);
          gl_FragColor = vec4(vec3(brightness), 1.0);
        }
      `,
    });

    outerWireframe = new THREE.Mesh(outerGeo, wireMaterial);
    innerSphere    = new THREE.Mesh(innerGeo, coreMaterial);

    shieldGroup.add(outerWireframe);
    shieldGroup.add(innerSphere);
    scene.add(shieldGroup);

    // ─── Observers ──────────────────────────────────────────────────────────
    const intersectionObserver = new IntersectionObserver(
      ([entry]) => { isInViewport = entry.isIntersecting; syncLoop(); },
      { threshold: 0 }
    );
    intersectionObserver.observe(container);

    const onVisibilityChange = () => { isTabVisible = !document.hidden; syncLoop(); };
    document.addEventListener('visibilitychange', onVisibilityChange);

    window.addEventListener('resize', onResize);
    window.addEventListener('mousemove', onMouseMove);

    // ─── Cleanup ────────────────────────────────────────────────────────────
    document.addEventListener('astro:before-swap', () => {
      stopLoop();
      intersectionObserver.disconnect();
      document.removeEventListener('visibilitychange', onVisibilityChange);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('mousemove', onMouseMove);
      renderer.dispose();
      effect.domElement.remove();
    }, { once: true });
  }

  // ─── Handlers ─────────────────────────────────────────────────────────────────
  function onResize() {
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    effect.setSize(container.clientWidth, container.clientHeight);
  }

  function onMouseMove(e: MouseEvent) {
    // Window-relative tracking — preserved from original
    mouse.x =  (e.clientX / window.innerWidth)  * 2 - 1;
    mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
  }

  // ─── Animation loop ───────────────────────────────────────────────────────────
  function animate() {
    animFrameId = requestAnimationFrame(animate);

    // Slow counter-rotation between cage and core — preserved
    outerWireframe.rotation.y += 0.0006;
    outerWireframe.rotation.x += 0.0005;
    innerSphere.rotation.y    -= 0.001;

    // Mouse parallax on the whole group — preserved
    shieldGroup.rotation.x += (mouse.y * 0.3 - shieldGroup.rotation.x) * 0.05;
    shieldGroup.rotation.z += (mouse.x * 0.3 - shieldGroup.rotation.z) * 0.05;

    shieldGroup.position.x += (mouse.x * 20 - shieldGroup.position.x) * 0.05;
    shieldGroup.position.y += (mouse.y * 20 - shieldGroup.position.y) * 0.05;

    effect.render(scene, camera);
  }

  // ─── Boot — IntersectionObserver decides when to start ───────────────────────
  init();
</script>