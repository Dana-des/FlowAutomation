---
// Service 2 — Wireframe Simplex AI Blob / Intelligent Interaction
---

<div id="service-two-container" class="w-full h-full" aria-hidden="true"></div>

<script>
  import * as THREE from 'https://unpkg.com/three@0.160.0/build/three.module.js';
  import { AsciiEffect } from 'https://unpkg.com/three@0.160.0/examples/jsm/effects/AsciiEffect.js';

  let scene, camera, renderer, effect, lines, material, geometry;
  let animFrameId = null;
  let isInViewport = false;
  const container = document.getElementById('service-two-container');
  const mouse = { x: 0, y: 0 };

  // --- Simplex Noise GLSL Function (Required for the organic AI feel) ---
  const simplexNoiseGLSL = `
    vec3 mod289(vec3 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec4 mod289(vec4 x) { return x - floor(x * (1.0 / 289.0)) * 289.0; }
    vec4 permute(vec4 x) { return mod289(((x*34.0)+1.0)*x); }
    vec4 taylorInvSqrt(vec4 r) { return 1.79284291400159 - 0.85373472095314 * r; }
    float snoise(vec3 v) {
      const vec2 C = vec2(1.0/6.0, 1.0/3.0);
      const vec4 D = vec4(0.0, 0.5, 1.0, 2.0);
      vec3 i = floor(v + dot(v, C.yyy));
      vec3 x0 = v - i + dot(i, C.xxx);
      vec3 g = step(x0.yzx, x0.xyz);
      vec3 l = 1.0 - g;
      vec3 i1 = min(g.xyz, l.zxy);
      vec3 i2 = max(g.xyz, l.zxy);
      vec3 x1 = x0 - i1 + C.xxx;
      vec3 x2 = x0 - i2 + C.yyy;
      vec3 x3 = x0 - D.yyy;
      i = mod289(i);
      vec4 p = permute(permute(permute(
                i.z + vec4(0.0, i1.z, i2.z, 1.0 ))
              + i.y + vec4(0.0, i1.y, i2.y, 1.0 ))
              + i.x + vec4(0.0, i1.x, i2.x, 1.0 ));
      float n_ = 0.142857142857;
      vec3 ns = n_ * D.wyz - vec3(1.0, 0.0, 1.0);
      vec4 j = p - 49.0 * floor(p * ns.z * ns.z);
      vec4 x_ = floor(j * ns.z);
      vec4 y_ = floor(j - 7.0 * x_);
      vec4 x = x_ * ns.x + ns.yyyy;
      vec4 y = y_ * ns.x + ns.yyyy;
      vec4 h = 1.0 - abs(x) - abs(y);
      vec4 b0 = vec4(x.xy, y.xy);
      vec4 b1 = vec4(x.zw, y.zw);
      vec4 s0 = floor(b0)*2.0 + 1.0;
      vec4 s1 = floor(b1)*2.0 + 1.0;
      vec4 sh = -step(h, vec4(0.0));
      vec4 a0 = b0.xzyw + s0.xzyw*sh.xxyy;
      vec4 a1 = b1.xzyw + s1.xzyw*sh.zzww;
      vec3 p0 = vec3(a0.xy,h.x);
      vec3 p1 = vec3(a0.zw,h.y);
      vec3 p2 = vec3(a1.xy,h.z);
      vec3 p3 = vec3(a1.zw,h.w);
      vec4 norm = taylorInvSqrt(vec4(dot(p0,p0), dot(p1,p1), dot(p2, p2), dot(p3,p3)));
      p0 *= norm.x; p1 *= norm.y; p2 *= norm.z; p3 *= norm.w;
      vec4 m = max(0.6 - vec4(dot(x0,x0), dot(x1,x1), dot(x2,x2), dot(x3,x3)), 0.0);
      m = m * m;
      return 42.0 * dot(m*m, vec4(dot(p0,x0), dot(p1,x1), dot(p2,x2), dot(p3,x3)));
    }
  `;

  function init() {
    if (!container) return;
    scene = new THREE.Scene();
    scene.background = null;

    camera = new THREE.PerspectiveCamera(50, container.clientWidth / container.clientHeight, 1, 1000);
    camera.position.z = 400;

    renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
    renderer.setClearColor(0x000000, 0);

    effect = new AsciiEffect(renderer, ' .:-=+*#%@', { invert: false, resolution: 0.15 });
    effect.setSize(container.clientWidth, container.clientHeight);

    Object.assign(effect.domElement.style, {
      color: '#336FE8',
      backgroundColor: 'transparent',
      fontFamily: 'monospace',
      fontSize: '18px',
      fontWeight: '500',
      textShadow: `
        0px 0px 4px rgba(72, 22, 238, 1),
        0px 0px 12px rgba(72, 22, 238, 1),
        0px 0px 24px rgba(72, 22, 238, 0.8)
      `,
    });
    container.appendChild(effect.domElement);

    // ─── Wireframe Geometry ───────────────────────────────────────────
    // Icosahedron detail (25) provides clean, angular triangular wireframes.
    const baseGeometry = new THREE.IcosahedronGeometry(130, 25);
    // Convert the solid faces into lines. This is critical for the architectural look.
    geometry = new THREE.WireframeGeometry(baseGeometry);

    // ─── Line Shader Material ──────────────────────────────────────────
    // This shader deforms the LINES themselves organically over time.
    material = new THREE.ShaderMaterial({
      uniforms: { uTime: { value: 0 } },
      vertexShader: `
        ${simplexNoiseGLSL} // Inject noise math
        varying float vNoise;
        uniform float uTime;

        void main() {
          // Layered noise for organic flow (exact same math as solid blob, applied to lines)
          float noise = snoise(vec3(position * 0.008 + uTime * 0.1));
          float noise2 = snoise(vec3(position * 0.01 + uTime * 0.15)) * 0.5;
          vNoise = noise + noise2; // Pass noise to fragment for varying line color intensity

          // Deform the line vertices
          vec3 newPosition = position + normal * vNoise * 25.0;

          gl_Position = projectionMatrix * modelViewMatrix * vec4(newPosition, 1.0);
        }
      `,
      fragmentShader: `
        varying float vNoise;
        void main() {
          // Make lines brighter where the blob "bulges" (more noise)
          float brightness = smoothstep(-1.0, 1.5, vNoise) + 0.3;
          gl_FragColor = vec4(vec3(brightness), 1.0); // Output to ASCII renderer
        }
      `,
      transparent: true,
      blending: THREE.AdditiveBlending, // Makes overlapping lines glow beautifully
    });

    // Replace THREE.Mesh with THREE.LineSegments for wireframe only rendering
    lines = new THREE.LineSegments(geometry, material);
    scene.add(lines);

    // Intersection Observer Control
    const observer = new IntersectionObserver(([e]) => {
      isInViewport = e.isIntersecting;
      if (isInViewport) animate();
      else if (animFrameId) cancelAnimationFrame(animFrameId);
    });
    observer.observe(container);

    window.addEventListener('resize', onResize);
    window.addEventListener('mousemove', (e) => {
      mouse.x = (e.clientX / window.innerWidth) * 2 - 1;
      mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
    });
  }

  function onResize() {
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    effect.setSize(container.clientWidth, container.clientHeight);
  }

  function animate() {
    animFrameId = requestAnimationFrame(animate);
    const time = performance.now() * 0.001;
    if (lines) {
      lines.material.uniforms.uTime.value = time;
      lines.rotation.y += 0.00008;
      // Parallax
      lines.position.x += (mouse.x * 20 - lines.position.x) * 0.05;
      lines.position.y += (mouse.y * 20 - lines.position.y) * 0.05;
    }
    effect.render(scene, camera);
  }

  init();
</script>