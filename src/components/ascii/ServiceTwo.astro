---
// src/components/ascii/ServiceTwo.astro
// Service 2 — Chrome Sphere / AI & Interaction
---

<div
  id="service-two-container"
  class="w-full h-full"
  aria-hidden="true"
></div>

<script>
  import * as THREE from 'three';
  import { AsciiEffect } from 'three/addons/effects/AsciiEffect.js';

  // ─── State ────────────────────────────────────────────────────────────────────
  let scene: THREE.Scene;
  let camera: THREE.PerspectiveCamera;
  let renderer: THREE.WebGLRenderer;
  let effect: AsciiEffect;
  let mesh: THREE.Mesh;
  let animFrameId: number | null = null;
  let isInViewport = false;
  let isTabVisible = !document.hidden;

  const container = document.getElementById('service-two-container') as HTMLElement;
  const mouse = { x: 0, y: 0 };

  // ─── Loop control ─────────────────────────────────────────────────────────────
  function startLoop() {
    if (animFrameId !== null) return;
    animFrameId = requestAnimationFrame(animate);
  }
  function stopLoop() {
    if (animFrameId === null) return;
    cancelAnimationFrame(animFrameId);
    animFrameId = null;
  }
  function syncLoop() {
    isInViewport && isTabVisible ? startLoop() : stopLoop();
  }

  // ─── Init ─────────────────────────────────────────────────────────────────────
  function init() {
    scene = new THREE.Scene();
    // null = transparent — characters appear only on the lit surface,
    // not as a full-screen fill (same fix applied to ServiceFlow)
    scene.background = null;

    camera = new THREE.PerspectiveCamera(
      50,
      container.clientWidth / container.clientHeight,
      1,
      1000
    );
    camera.position.z = 400; // preserved

    renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1));
    renderer.setClearColor(0x000000, 1);

    effect = new AsciiEffect(renderer, ' .:-=+*#%@', {
      invert: true, // false = characters on bright areas only → transparent bg
      resolution: 0.15,
    });
    effect.setSize(container.clientWidth, container.clientHeight);

    // Colors and glow — preserved exactly
    Object.assign(effect.domElement.style, {
      color: '#336FE8',
      backgroundColor: 'transparent',
      fontFamily: 'monospace',
      fontSize: '18px',
      fontWeight: '500',
      textShadow: `
        0px 0px 4px rgba(51, 111, 232, 0.8),
        0px 0px 12px rgba(51, 111, 232, 0.8),
        0px 0px 24px rgba(51, 111, 232, 0.8)
      `,
    });

    container.appendChild(effect.domElement);

    // ─── Geometry: Icosahedron — preserved (detail 40 for smooth pulse) ──────
    const geometry = new THREE.IcosahedronGeometry(120, 40);

    // ─── Shader: Organic Vocal Pulse + Chrome Lighting — preserved exactly ───
    const material = new THREE.ShaderMaterial({
      uniforms: {
        uTime: { value: 0 },
      },
      vertexShader: /* glsl */ `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        uniform float uTime;

        void main() {
          vNormal = normalize(normalMatrix * normal);

          // Organic Vocal Pulse Logic — preserved
          float pulse = sin(uTime * 2.0) * 0.1;
          float noise = sin(position.x * 0.05 + uTime)
                      * cos(position.y * 0.05 + uTime) * 8.0;

          vec3 newPosition = position + normal * (noise + (pulse * 20.0));

          vec4 mvPosition = modelViewMatrix * vec4(newPosition, 1.0);
          vViewPosition = -mvPosition.xyz;
          gl_Position = projectionMatrix * mvPosition;
        }
      `,
      fragmentShader: /* glsl */ `
        varying vec3 vNormal;
        varying vec3 vViewPosition;
        uniform float uTime;

        void main() {
          vec3 normal  = normalize(vNormal);
          vec3 viewDir = normalize(vViewPosition);

          // High-Contrast Chrome Lighting — preserved exactly
          vec3 lightDir = normalize(vec3(1.0, 1.0, 1.0));
          float diffuse = max(dot(normal, lightDir), 0.0);

          vec3 fillLight = normalize(vec3(-1.0, -0.5, -1.0));
          float fill = max(dot(normal, fillLight), 0.0) * 0.3;

          vec3 halfVector = normalize(lightDir + viewDir);
          float specular = pow(max(dot(normal, halfVector), 0.0), 25.0) * 1.5;

          float brightness = diffuse + specular;
            brightness = smoothstep(0.1, 1.0, brightness);

            // Add ambient AFTER smoothstep so it isn't crushed to zero.
            // Lifts sphere-geometry pixels ~0.08 above the black clear color (0.0),
            // making the dark bottom render faint characters instead of disappearing.
            brightness += 0.08;

          gl_FragColor = vec4(vec3(brightness), 1.0);
        }
      `,
    });

    mesh = new THREE.Mesh(geometry, material);
    scene.add(mesh);

    // ─── Observers ──────────────────────────────────────────────────────────
    const intersectionObserver = new IntersectionObserver(
      ([entry]) => { isInViewport = entry.isIntersecting; syncLoop(); },
      { threshold: 0 }
    );
    intersectionObserver.observe(container);

    const onVisibilityChange = () => { isTabVisible = !document.hidden; syncLoop(); };
    document.addEventListener('visibilitychange', onVisibilityChange);

    window.addEventListener('resize', onResize);
    window.addEventListener('mousemove', onMouseMove);

    // ─── Cleanup ────────────────────────────────────────────────────────────
    document.addEventListener('astro:before-swap', () => {
      stopLoop();
      intersectionObserver.disconnect();
      document.removeEventListener('visibilitychange', onVisibilityChange);
      window.removeEventListener('resize', onResize);
      window.removeEventListener('mousemove', onMouseMove);
      renderer.dispose();
      effect.domElement.remove();
    }, { once: true });
  }

  // ─── Handlers ─────────────────────────────────────────────────────────────────
  function onResize() {
    camera.aspect = container.clientWidth / container.clientHeight;
    camera.updateProjectionMatrix();
    effect.setSize(container.clientWidth, container.clientHeight);
  }

  function onMouseMove(e: MouseEvent) {
    // Window-relative tracking — preserved from original
    mouse.x =  (e.clientX / window.innerWidth)  * 2 - 1;
    mouse.y = -(e.clientY / window.innerHeight) * 2 + 1;
  }

  // ─── Animation loop ───────────────────────────────────────────────────────────
  function animate() {
    animFrameId = requestAnimationFrame(animate);

    // Drive the pulse shader with wall-clock time — preserved
    const time = performance.now() * 0.001;
    if (mesh.material instanceof THREE.ShaderMaterial) {
      mesh.material.uniforms.uTime.value = time;
    }

    mesh.rotation.y += 0.002; // slow rotation — preserved

    // Mouse parallax — preserved
    mesh.rotation.x += (mouse.y * 0.5 - mesh.rotation.x) * 0.05;
    mesh.rotation.z += (mouse.x * 0.5 - mesh.rotation.z) * 0.05;

    mesh.position.x += (mouse.x * 20 - mesh.position.x) * 0.05;
    mesh.position.y += (mouse.y * 20 - mesh.position.y) * 0.05;

    effect.render(scene, camera);
  }

  // ─── Boot — IntersectionObserver decides when to start ───────────────────────
  init();
</script>