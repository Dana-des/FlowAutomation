---
import Button from "./Button.astro";
---

<section id="home"
  aria-labelledby="hero-heading"
  class="flex min-h-screen flex-col bg-bg"
>
  <div
    class="page-container flex flex-1 flex-col justify-center py-24 md:py-32"
  >
    <div class="mx-auto flex w-full max-w-4xl flex-col items-center gap-10">
      <div class="flex flex-col items-center gap-4 text-center">
        <p class="text-h6 uppercase tracking-wide text-text/80">
          [ BUSINESS PROCESS AUTOMATION ]
        </p>

        <h1
          id="hero-heading"
          class="text-h1 text-text md:text-h1"
        >
          <span class="block">
            Power Your <span class="font-thin">Growth</span>
          </span> with Automation
        </h1>

        <p class="max-w-xl text-body text-text/80">
          Smart custom software and integrations engineered to boost your business
          performance by up to 300%
        </p>
      </div>

      <div
        class="flex w-full max-w-md flex-col gap-4 md:max-w-none md:flex-row md:justify-center"
      >
        <Button
          variant="primary"
          href="#book-audit"
          label="Book audit →"
          class="w-full md:w-auto"
        />
        <Button
          variant="secondary"
          href="#what-we-do"
          label="What we do"
          class="w-full md:w-auto"
        />
      </div>
    </div>
  </div>
</section>
