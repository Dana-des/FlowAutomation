---
import Button from "./Button.astro";
---

<section id="home"
  aria-labelledby="hero-heading"
  class="relative z-10 flex min-h-screen flex-col"
>


  <div
    class="relative page-container flex flex-1 flex-col justify-center py-24 md:py-32"
  >
    <div class="mx-auto flex w-full max-w-4xl flex-col items-center gap-10">
      <div class="flex flex-col items-center gap-4 text-center">
        <p class="reveal-top delay-1 text-h6 uppercase text-text/80">
          [ BUSINESS PROCESS AUTOMATION ]
        </p>

        <h1
          id="hero-heading"
          class="reveal text-h1 text-text lg:text-h1-lg"
        >
          <span class="block">
            Power Your Growth with Automation
            </span>
        </h1>

        <p class="reveal delay-1 max-w-xl text-body text-text/80">
          Smart custom software and integrations engineered to boost your business
          performance by up to 300%
        </p>
      </div>

      <div
        class="reveal-ui delay-4 flex w-full max-w-md flex-col gap-4 md:max-w-none md:flex-row md:justify-center"
      >
        <Button
          variant="primary"
          href="#contact"
          label="Book audit →"
          class="w-full md:w-auto"
        />
        <Button
          variant="secondary"
          href="#services"
          label="What we do"
          class="w-full md:w-auto"
        />
      </div>
    </div>
  </div>
</section>
