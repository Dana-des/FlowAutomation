---
// src/sections/Services.astro
import Text from "../components/Button.astro";
import ServiceOne from '../components/ascii/ServiceOne.astro';
import ServiceTwo   from '../components/ascii/ServiceTwo.astro';
import ServiceThree from '../components/ascii/ServiceThree.astro';
import ServiceFour  from '../components/ascii/ServiceFour.astro';

const services = [
  {
    id: " 01 ",
    title: "Automation & Operations",
    heading: "Manual work slowing you down?",
    description:
      "Consolidate disconnected tools into a high-speed system that runs your business end-to-end.",
    cards: [
      {
        title: "Workflow Automation",
        description: "We replace manual processes with structured workflows that run reliably and scale with your operations.",
        outcomes: ["Process mapping & bottleneck analysis", "Conditional logic & triggers", "Error-safe workflows"],
      },
      {
        title: "System Integration",
        description: "We connect your tools into a unified system with seamless data flow across platforms.",
        outcomes: ["API integrations & middleware", "Real-time, bi-directional sync", "Cross-system workflow orchestration"],
      },
      {
        title: "FinOps",
        description: "We bring visibility and control to your infrastructure costs without sacrificing performance.",
        outcomes: ["Cost analysis & optimization", "Resource usage monitoring", "Scalable infrastructure planning"],
      },
    ],
  },
  {
    id: " 02 ",
    title: "AI & Interaction",
    heading: "Slow responses killing growth?",
    description:
      "Scale your communication with systems that act and respond instantly.",
    cards: [
      {
        title: "Automated Conversations",
        description: "We turn repetitive communication into structured systems that respond, act, and trigger workflows automatically.",
        outcomes: ["Telegram, Slack, WhatsApp bots", "Conversation logic & command flows", "System-triggered actions & responses"],
      },
    ],
  },
  {
    id: " 03 ",
    title: "Product & Engineering",
    heading: "Current tools don't fit?",
    description:
      "Stop adapting to rigid software. Build systems that adapt to your workflow.",
    cards: [
      {
        title: "Custom Software",
        description: "We design and build internal tools and systems tailored to your exact business processes.",
        outcomes: ["Business logic architecture", "Scalable backend systems", "Admin panels & internal tools"],
      },
      {
        title: "Web Development",
        description: "We create high-performance websites and platforms aligned with your product and business goals.",
        outcomes: ["Frontend & backend development", "Performance and scalability optimization", "CMS or custom-built solutions"],
      },
    ],
  },
  {
    id: " 04 ",
    title: "Security",
    heading: "Unseen risks in your data?",
    description:
      "Shield your entire infrastructure by neutralizing threats before they become liabilities.",
    cards: [
      {
        title: "Security Assessment (Pentest)",
        description: "We identify and eliminate critical vulnerabilities before they can be exploited in real-world scenarios.",
        outcomes: ["Application & infrastructure testing", "Business logic and access control analysis", "Clear remediation plan & re-testing"],
      },
    ],
  },
];
---

<!--
  z-10 + bg-bg: this section sits above the fixed hero animation underneath.
  The solid background covers the hero; the ASCII animations render on top of
  that background, visible only where the 3D shape has bright rim pixels.
-->
<section id="services" class="relative z-10 bg-bg text-text">

  <!-- Heading -->
  <div class="container max-w-content pt-section-m md:pt-section-d">
    <h2 class="reveal text-h2 text-center mb-20 md:mb-40 lg:text-h2-lg">Systems we build</h2>
  </div>

  <!-- ─── Service groups ──────────────────────────────────────────────────── -->
  
  <div class="flex flex-col gap-20 md:gap-40 pb-section-m md:pb-section-d">

    {services.map((service, i) => (
      <div class="relative">

        <!--
          ASCII background layer — desktop only (hidden on mobile for perf).
          sticky top-0 h-screen: always viewport-sized so Three.js renders
          at a consistent resolution regardless of how tall the content is.
          pointer-events-none: clicks pass through to the content above.
          z-0: sits behind the content grid (z-10).
        -->
        <div class="reveal-card delay-2 hidden md:block sticky top-0 h-screen overflow-hidden pointer-events-none z-0">
          {i === 0 && <ServiceOne />}
          {i === 1 && <ServiceTwo />}
          {i === 2 && <ServiceThree />}
          {i === 3 && <ServiceFour />}
        </div>

        <!--
          Content grid.
          md:-mt-[100vh]: on desktop, pulls the grid up to visually overlap
          the ASCII sticky div above. On mobile no offset — normal flow.
          relative z-10: sits in front of the ASCII layer.
        -->
        <div class="container max-w-content relative z-10 md:-mt-[100vh]">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-6">

            <!-- LEFT: service info ─────────────────────────────────────── -->
            <!--
              md:sticky md:top-0 md:h-screen md:items-center:
              pins this column to the viewport and centres its content
              vertically while the right column's cards scroll past.
            -->
            <div class="md:sticky md:top-0 md:h-screen flex md:items-center">
              <div class=" flex flex-col gap-4 max-w-[520px]">
                <h6 class="reveal text-h6 text-ui uppercase">
                  [{service.id}] {service.title}
                </h6>
                <h3 class="reveal delay-1 text-h3 lg:text-h3-lg">{service.heading}</h3>
                <p class="reveal delay-1 text-body text-text/80">{service.description}</p>
              </div>
            </div>

            <!-- RIGHT: cards ───────────────────────────────────────────── -->
            <!--
              md:my-[100vh]: adds 100vh top and bottom margin on desktop.
              This is what gives the left sticky column enough scroll runway
              to stay pinned through the entire card list. On mobile: no margin,
              cards just follow the left info block naturally.
            -->
            <div class="flex flex-col gap-6 md:my-[100vh]">

              {service.cards.map((card) => (
                <article class="reveal-card hover-border bg-surface/4 backdrop-blur-card p-card flex flex-col">

                  <div class="flex flex-col gap-4 mb-6">
                    <div class="flex items-center gap-2.5">
                      <div class="reveal-card delay-2 w-[10px] h-[10px] rounded-full bg-ui"></div>
                      <h5 class="reveal text-body">{card.title}</h5>
                    </div>
                    <p class="reveal delay-1 text-body text-text/80">{card.description}</p>
                  </div>

                  <div class="reveal h-px bg-line/10 mb-6"></div>

                  <Text variant="text" class="reveal delay-2 justify-start outcomes-btn">OUTCOMES +</Text>

                  <div class="outcomes-content overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out">
                    <div class="pt-4 flex flex-col gap-1 text-text/80">
                      {card.outcomes.map((outcome) => (
                        <p>→ {outcome}</p>
                      ))}
                    </div>
                  </div>

                </article>
              ))}

            </div>

          </div>
        </div>

      </div>
    ))}

  </div>

</section>


<script>
  // Outcomes expand / collapse — unchanged from original
  document.querySelectorAll('.outcomes-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      const content = btn.nextElementSibling as HTMLElement;
      const label   = btn.querySelector('*')  as HTMLElement;
      const isOpen  = content.classList.contains('open');

      if (isOpen) {
        content.style.maxHeight = '0px';
        content.style.opacity   = '0';
        content.classList.remove('open');
        label.textContent = 'OUTCOMES +';
      } else {
        content.classList.add('open');
        content.style.maxHeight = content.scrollHeight + 'px';
        content.style.opacity   = '1';
        label.textContent       = 'OUTCOMES −';
      }
    });
  });
</script>