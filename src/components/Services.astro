---
import Text from "../components/Button.astro";

const services = [
  {
    id: " 01 ",
    title: "Automation & Operations",
    heading: "Manual work slowing you down?",
    description:
      "Consolidate disconnected tools into a high-speed system that runs your business end-to-end.",
    cards: [
      {
        title: "Workflow Automation",
        description: "We replace manual processes with structured workflows that run reliably and scale with your operations.",
        outcomes: ["Process mapping & bottleneck analysis", "Conditional logic & triggers", "Error-safe workflows"]
      },
      {
        title: "System Integration",
        description: "We connect your tools into a unified system with seamless data flow across platforms.",
        outcomes: ["API integrations & middleware", "Real-time, bi-directional sync", "Cross-system workflow orchestration"]
      },
      {
        title: "FinOps",
        description: "We bring visibility and control to your infrastructure costs without sacrificing performance.",
        outcomes: ["Cost analysis & optimization", "Resource usage monitoring", "Scalable infrastructure planning"]
      }
    ],
  },
  {
    id: " 02 ",
    title: "AI & Interaction",
    heading: "Slow responses killing growth?",
    description:
      "Scale your communication with systems that act and respond instantly.",
    cards: [
      {
        title: "Automated Conversations",
        description: "We turn repetitive communication into structured systems that respond, act, and trigger workflows automatically.",
        outcomes: ["Telegram, Slack, WhatsApp bots", "Conversation logic & command flows", "System-triggered actions & responses"]
      }
    ],
  },
  {
    id: " 03 ",
    title: "Product & Engineering",
    heading: "Current tools don’t fit?",
    description:
      "Stop adapting to rigid software. Build systems that adapt to your workflow.",
    cards: [
      {
        title: "Custom Software",
        description: "We design and build internal tools and systems tailored to your exact business processes.",
        outcomes: ["Business logic architecture", "Scalable backend systems", "Admin panels & internal tools"]
      },
      {
        title: "Web Development",
        description: "We create high-performance websites and platforms aligned with your product and business goals.",
        outcomes: ["Frontend & backend development", "Performance and scalability optimization", "CMS or custom-built solutions"]
      }
    ],
  },
  {
    id: " 04 ",
    title: "Security",
    heading: "Unseen risks in your data?",
    description:
      "Shield your entire infrastructure by neutralizing threats before they become liabilities.",
    cards: [
      {
        title: "Security Assessment (Pentest)",
        description: "We identify and eliminate critical vulnerabilities before they can be exploited in real-world scenarios.",
        outcomes: ["Application & infrastructure testing", "Business logic and access control analysis", "Clear remediation plan & re-testing"]
      }
    ],
  },
];
---

<section id="services" class="bg-bg text-text">
  <div class="container max-w-content py-section-m md:py-section-d">

    <!-- Heading -->
    <h2 class="text-h2 text-center mb-20 lg:text-h2-lg">Systems we build</h2>

    <div class="flex flex-col gap-[160px]">
      {services.map((service) => (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

          <!-- LEFT -->
          <div class="md:sticky md:top-0 md:h-screen flex md:items-center">
            <div class="flex flex-col gap-4 max-w-[520px]">
              <h6 class="text-h6 text-ui uppercase">
                [{service.id}] {service.title}
              </h6>
              <h3 class="text-h3 lg:text-h3-lg">{service.heading}</h3>
              <p class="text-body text-text/80">
                {service.description}
              </p>
            </div>
          </div>

          <!-- RIGHT -->
          <div class="flex flex-col gap-6 md:my-[100vh]">
            {service.cards.map((card) => (

              <!-- Removed 'gap-6' here to fix the spacing issue -->
              <article class="hover-border bg-surface/4 backdrop-blur-card p-card flex flex-col">

                <!-- Content (Added mb-6 here) -->
                <div class="flex flex-col gap-4 mb-6">
                  <div class="flex items-center gap-2.5">
                    <div class="w-[10px] h-[10px] rounded-full bg-ui"></div>
                    <h5 class="text-body">{card.title}</h5>
                  </div>
                  <p class="text-body text-text/80">
                    {card.description}
                  </p>
                </div>

                <!-- Divider (Added mb-6 here) -->
                <div class="h-px bg-line/10 mb-6"></div>

                <!-- Button -->
                <div class="outcomes-btn inline-block cursor-pointer">
                  <Text variant="text">OUTCOMES +</Text>
                </div>

                <!-- Expand (Added pt-4 inside so space only appears when open) -->
                <div class="outcomes-content overflow-hidden max-h-0 opacity-0 transition-all duration-500 ease-in-out">
                  <div class="pt-4 flex flex-col gap-1 text-text/80">
                    {card.outcomes.map((outcome) => (
                      <p>→ {outcome}</p>
                    ))}
                  </div>
                </div>

              </article>

            ))}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>

<script>
  const buttons = document.querySelectorAll(".outcomes-btn");

  buttons.forEach((btn) => {
    // 1. Add 'e' (the event object) as a parameter
    btn.addEventListener("click", (e) => {
      
      // 2. Stop the browser from jumping to the top of the page
      e.preventDefault(); 

      const content = btn.nextElementSibling;
      const label = btn.querySelector("*"); // grabs inner element safely

      const isOpen = content.classList.contains("open");

      if (isOpen) {
        content.style.maxHeight = "0px";
        content.style.opacity = "0";
        content.classList.remove("open");
        label.textContent = "OUTCOMES +";
      } else {
        content.classList.add("open");
        content.style.maxHeight = content.scrollHeight + "px";
        content.style.opacity = "1";
        label.textContent = "OUTCOMES −";
      }
    });
  });
</script>