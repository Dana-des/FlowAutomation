---
const socials = [
  { name: "Telegram", icon: "/Icons/Telegram.svg", link: "https://t.me/Groot_Ben" },
  { name: "WhatsApp", icon: "/Icons/WhatsApp.svg", link: "https://wa.me/+393513379783" },
  { name: "Discord", icon: "/Icons/Discord.svg", link: "https://discord.gg/no_name_no_id" },
  { name: "LinkedIn", icon: "/Icons/LinkedIn.svg", link: "https://www.linkedin.com/in/artem-zlobin%F0%9F%87%AE%F0%9F%87%B9-518173347?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=ios_app" },
];
---

<footer class="relative z-10 w-full overflow-hidden bg-bg py-[80px] text-text">
  <div class="container max-w-content flex flex-col gap-[80px]">
    
    <!-- Top Section: Columns Layout -->
    <div class="flex flex-col md:flex-row gap-12 md:gap-0 w-full justify-between">
      
      <!-- Left Column: 50% (Logo & Copyright) -->
      <div class="flex w-full flex-col gap-2 md:w-1/2">
        <div class="flex items-center gap-2.5">
          <!-- Blue Dot -->
          <span class="block h-2.5 w-2.5 rounded-full bg-ui"></span>
          <span class="text-body">FlowAutomation</span>
        </div>
        <p class="max-w-[320px] text-h6 font-normal leading-[1.4] text-text/60">
          © 2026 FlowAutomation — Smart IT Solutions for Global Business
        </p>
      </div>

      <!-- Right Column: 50% (Menu Links in 3 Columns) -->
      <nav class="grid w-full grid-cols-2 gap-8 md:w-1/2 md:grid-cols-3" aria-label="Footer Navigation">
        
        <!-- ABOUT -->
        <div class="flex flex-col gap-4">
          <h6 class="text-small uppercase font-normal text-text/20">About</h6>
          <ul class="flex flex-col gap-2">
            <li><a href="#why-us" class="block text-small font-normal text-text/80 transition-colors duration-300 hover:text-text/60">Why us</a></li>
            <li><a href="#tech-stack" class="block text-small font-normal text-text/80 transition-colors duration-300 hover:text-text/60">Technology stack</a></li>
          </ul>
        </div>

        <!-- SERVICES -->
        <div class="flex flex-col gap-4">
          <h6 class="text-small uppercase font-normal text-text/20">Services</h6>
          <ul class="flex flex-col gap-2">
            <li><a href="#automation-operations" class="block text-small font-normal text-text/80 transition-colors duration-300 hover:text-text/60">Automation & Operations</a></li>
            <li><a href="#ai-interaction" class="block text-small font-normal text-text/80 transition-colors duration-300 hover:text-text/60">AI & Interaction</a></li>
            <li><a href="#product-engineering" class="block text-small font-normal text-text/80 transition-colors duration-300 hover:text-text/60">Product & Engineering</a></li>
            <li><a href="#security" class="block text-small font-normal text-text/80 transition-colors duration-300 hover:text-text/60">Security</a></li>
          </ul>
        </div>

        <!-- CONTACT -->
        <div class="flex flex-col gap-4">
          <h6 class="text-small uppercase font-normal text-text/20">Contact</h6>
          <div class="flex flex-col gap-2">
            <a href="mailto:info@flowautomation.eu" class="text-small font-normal text-text/80 transition-colors duration-300 hover:text-text/60">
              info@flowautomation.eu
            </a>
            
            <!-- Social Media Icons Wrapper -->
            <div class="mt-2 flex items-center gap-4">
              {socials.map((social) => (
                <a 
                  href={social.link} 
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={social.name}
                  class="transition-opacity duration-300 hover:opacity-60"
                >
                  <img 
                    src={social.icon} 
                    alt={`${social.name} icon`} 
                    class="h-6 w-6 object-contain" 
                    loading="lazy" 
                  />
                </a>
              ))}
            </div>
          </div>
        </div>

      </nav>
    </div>

    <!-- Bottom Section: Huge Marquee Logo Text -->
<div class="reveal delay-1 footer-marquee" aria-hidden="true">
  <div class="footer-marquee-track">
    <span class="huge-text">FlowAutomation</span>
    <span class="huge-text">FlowAutomation</span>
    <span class="huge-text">FlowAutomation</span>
    <span class="huge-text">FlowAutomation</span>
  </div>
</div>

<style>
  .footer-marquee {
    width: 100%;
    /* FIX 1: Prevent text from spilling out and creating rogue horizontal window scrollbars */
    overflow: visible; 
  }

  .footer-marquee-track {
    display: flex;
    width: max-content;
    animation: marquee 50s linear infinite;
  }

  .huge-text {
    flex: 0 0 auto;
    /* FIX 2: Changed to a fixed rem padding. Using font-relative 'em' padding 
       causes sub-pixel rounding errors that make the loop jitter and skip. */
    padding-right: 4rem; 
    font-family: Sora, sans-serif;
    font-size: clamp(3rem, 13vw, 180px);
    line-height: 0.85;
    letter-spacing: -0.04em;
    white-space: nowrap;
    color: rgb(var(--c-ui));
  }

  @keyframes marquee {
    from {
      transform: translateX(0);
    }
    to {
      /* FIX 3: Shifting -50% of a 4-item track moves exactly 2 items out of view. 
         The remaining 2 items perfectly mirror the starting position, creating an invisible reset. */
      transform: translateX(-50%);
    }
  }
</style>