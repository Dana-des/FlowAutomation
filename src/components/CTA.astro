---
import AsciiScene from "../components/AsciiScene.astro";
import ContactForm from "./ContactForm.astro";

const socials = [
  { name: "Telegram", icon: "/Icons/Telegram.svg", link: "https://t.me/Groot_Ben" },
  { name: "WhatsApp", icon: "/Icons/WhatsApp.svg", link: "https://wa.me/+393513379783" },
  { name: "Discord", icon: "/Icons/Discord.svg", link: "https://discord.gg/no_name_no_id" },
  { name: "LinkedIn", icon: "/Icons/LinkedIn.svg", link: "https://www.linkedin.com/in/artem-zlobin%F0%9F%87%AE%F0%9F%87%B9-518173347?utm_source=share&utm_campaign=share_via&utm_content=profile&utm_medium=ios_app" },
];
---

<section id="contact" class="relative z-10 flex w-full flex-col items-center gap-20 bg-transparent py-section-m text-text md:py-section-d">


  <h2 class="reveal max-w-4xl text-center text-h2 text-text lg:text-h2-lg">
    Ready to automate your business? Contact us today
  </h2>

  <!-- Form Container -->
  <!-- w-full ensures it fills width on mobile; max-w sets the desktop boundary -->
  <div class="w-full md:w-[calc(50%-12px)] md:mx-auto px-4 md:px-0">
    <ContactForm />
  </div>

  <!-- Social Media & Email Row -->
  <div class="flex w-full flex-wrap items-center justify-center gap-5 px-4">
    
    <!-- Label -->
    <span class="text-h6 uppercase text-text/60">
      Find us on social media
    </span>

    <!-- Social Icons Container -->
    <div class="flex gap-2">
      {socials.map((social) => (
        <a 
          href={social.link}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={social.name}
          class="hover-border flex h-[52px] w-[52px] items-center justify-center rounded-none bg-surface/4 backdrop-blur-card"
        >
          <img 
            src={social.icon} 
            alt={`${social.name} icon`} 
            class="h-6 w-6" 
            loading="lazy" 
          />
        </a>
      ))}
    </div>

    <!-- Email Card -->
    <!-- py-2 = 8px, px-4 = 16px -->
    <a 
      href="mailto:info@flowautomation.eu" 
      class="hover-border flex h-[52px] items-center rounded-none bg-surface/4 px-4 py-2 text-h6 lowercase backdrop-blur-card"
    >
      info@flowautomation.eu
    </a>

  </div>

</section>